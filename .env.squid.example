# DeepSeaSquid v0 config — comment-only, dry-run-capable, pinned to Claude Sonnet
#
# NOTE: The agent reads os.environ directly — there is no dotenv auto-loading.
# To use this file, source it before running:
#   source .env.squid.example
# Or export all non-comment lines:
#   export $(grep -v '^#' .env.squid.example | xargs)
# Or configure env vars in your PM2 ecosystem.config.js / launchd plist.
#
# ── Mac Mini deployment notes ─────────────────────────────────────────────
# 1. The process env on the Mac Mini MUST include Homebrew's bin dir — `claude`
#    and `node` live there, and PM2/launchd/cron commonly start with a stripped
#    PATH that misses it:
#      export PATH=/opt/homebrew/bin:$PATH
# 2. PROVIDER_ORDER may later grow to `claude,opencode` to add a DeepSeek
#    backup via OpenCode. At the time this template was written, `opencode`
#    was NOT installed on this machine (`which opencode` found nothing) —
#    install + configure it (OPENCODE_BIN / OPENCODE_MODEL) before adding it
#    to PROVIDER_ORDER, on both this machine and the Mac Mini.

# Leviathan News API
export LN_API=https://api.leviathannews.xyz/api/v1

# ─── Agent identity ──────────────────────────────────────────────────────────

export AGENT_NAME=DeepSeaSquid

# ─── Comment-only / dry-run chassis (v0) ─────────────────────────────────────

# Skip Telegram channel scanning + article evaluation/submission (Phases 1-3)
# entirely; run only vote/comment (Phase 4) and reply-walking (Phase 5). No
# Telegram session, CHANNELS, or BOT_HQ_GROUP_ID required in this mode — LN
# wallet auth (below) is still required.
export COMMENT_ONLY=1

# LNClient write methods (post_yap/vote/submit_article) log the would-be
# request to dry_run.log instead of hitting the API. Read-only calls (auth,
# get_recent_articles, get_yaps) still hit the network normally. Flip to 0
# once you've reviewed dry_run.log and are ready to post for real.
export DRY_RUN=1

# Seconds between cycles (default: 3600 = 1 hour)
export CYCLE_INTERVAL=1800   # 30 min — beats Benthic's ~38min median comment lag

# Safety cap on new-article comments posted per cycle. Articles beyond the cap
# are left uncommented (not marked) so a later cycle picks them up.
export MAX_COMMENTS_PER_CYCLE=8   # coverage headroom; gate routes most articles to the cheap SHORT/levity register

# ─── Voting (Phase 4) ─────────────────────────────────────────────────────────

# DISABLED by default — do NOT flip to 1 without reading this first.
#
# The classification-tier LLM (pinned to Sonnet via CLAUDE_BIN below) is
# empirically unsafe as a vote judge: evaluate_comment_quality() returned -1
# (downvote) three times out of three on a genuinely insightful, well-sourced
# comment, and batch_evaluate_comments() repeatedly false-positived its own
# task prompt as a prompt-injection attempt under Sonnet, failed to parse,
# and fell through to that same broken individual-eval path. Net effect: the
# bot casts unjustified downvotes on real contributors.
#
# DeepSeaSquid v0 is a COMMENTER (Social lane), not a moderator (Moderation
# lane) — it must not vote at all. Article/comment GATING and COMMENTING are
# entirely unaffected by this flag; only voting is gated.
#
# Do not enable without pinning the classification tier to a stronger model
# AND re-validating evaluate_comment_quality()/batch_evaluate_comments()
# against known-good comments first.
export VOTING_ENABLED=0

# ─── LLM provider — Claude only, pinned to Sonnet ────────────────────────────

# claude,codex,opencode is the upstream default (Codex primary). DeepSeaSquid
# runs Claude-only for v0 — see bin/claude-sonnet.sh below for how "sonnet" is
# pinned without patching providers.py.
export PROVIDER_ORDER=claude

# Wrapper script (chmod +x) — `exec claude --model sonnet "$@"`. providers.py's
# ClaudeProvider treats CLAUDE_BIN as an opaque executable path (it never
# inspects the binary's name), so this wrapper is a zero-patch pin: every
# invocation — creative tier and classification tier alike — resolves to
# `claude --model sonnet ...`. Update this path to wherever this repo is
# checked out on the target host (this is the path for the current checkout).
export CLAUDE_BIN=/Users/gerrithall/dev/leviathan/be-squid/bin/claude-sonnet.sh

# ─── Wallet auth ──────────────────────────────────────────────────────────────

# WALLET_KEY_FILE is honored by both agents: ln-agent.py's load_credentials()
# and benthic-bot.py both check WALLET_PRIVATE_KEY first, then fall back to
# reading the key from this path (default ~/.claude/.ln-wallet-key if unset).
export WALLET_KEY_FILE=~/.config/moltbook/.be-squid-wallet-key
# export WALLET_PRIVATE_KEY=

# Bot HQ Telegram group ID — NOT required in COMMENT_ONLY mode. Leave unset.
# export BOT_HQ_GROUP_ID=

# Telegram channels — NOT required in COMMENT_ONLY mode (Phase 1 never runs).
# export CHANNELS='["@examplechannel"]'

# ─── Operator alerting (alerts.py) ────────────────────────────────────────────

# When the LLM provider chain is dead (key/binary missing, quota exhausted,
# every provider failing), alerts.py sends ONE Telegram message to the
# operator — not one per cycle — and one more when it recovers. See
# alerts.py's module docstring for the full design.
#
# NOTE on naming: ln-agent.py's own .env.example documents an (unimplemented)
# ALERT_CHANNEL_ID for a different, future "cycle summary" feature. To avoid
# colliding with that reserved name, alerting config here is namespaced
# SQUID_ALERT_* instead of ALERT_*.

# Option A — set directly (wins over the .env file below if both are set):
# export SQUID_ALERT_BOT_TOKEN=
# export SQUID_ALERT_CHANNEL_ID=

# Option B — reuse firepanbot's existing Telegram bot config. Reads ONLY
# TELEGRAM_BOT_TOKEN and FIREPANBOT_OPERATOR_CHANNEL_ID from this file (every
# other key in it is ignored). This file exists at the default path below on
# the Mac Mini — it does NOT necessarily exist on a dev laptop, in which case
# alerting is silently disabled there (logged once at startup, never a crash).
# export ALERT_ENV_FILE=~/dev/firepan/tools/firepanbot/.env

# Master kill switch — 1 suppresses every alert (Telegram or, under DRY_RUN,
# the dry_run.log entry) regardless of the config above. Default: enabled.
export ALERT_DISABLE=0
